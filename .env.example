# LLM API 配置示例
# 复制此文件为 .env 并填入实际值

# 必填：LLM API 服务地址
# 示例：http://localhost:11434/v1 (Ollama) 或 https://api.deepseek.com/v1
LLM_BASE_URL=http://your-llm-server:port/v1

# 必填：LLM API 密钥
# 注意：不要将真实密钥提交到版本控制
LLM_API_KEY=your-api-key-here

# 必填：模型名称
LLM_MODEL=your-model-name

# 可选：并发配置（留空则自动根据Agent数量计算）
# 可选：并发策略（auto/local/remote，默认 auto）
LLM_CONCURRENCY_PROFILE=auto
LLM_MAX_CONCURRENT=
LLM_TIMEOUT=60
LLM_MAX_RETRIES=5
