# LLM API configuration example
# Copy this file to `.env` and fill in real values.

# Required: LLM API base URL
# Example: `http://localhost:11434/v1` for Ollama
# Example: `https://api.deepseek.com/v1` for DeepSeek-compatible APIs
LLM_BASE_URL=http://your-llm-server:port/v1

# Required: LLM API key
# Never commit a real secret into version control.
LLM_API_KEY=your-api-key-here

# Required: model name
LLM_MODEL=DeepSeek-V3.2

# Optional: dedicated LLM for intelligence reports.
# If omitted, report generation falls back to the main LLM settings above.
REPORT_LLM_BASE_URL=http://your-llm-server:port/v1
REPORT_LLM_API_KEY=your-report-api-key-here
REPORT_LLM_MODEL=DeepSeek-R1-0528-64k
REPORT_LLM_TIMEOUT=120
REPORT_LLM_MAX_TOKENS=2000
REPORT_LLM_TEMPERATURE=0.5

# Optional concurrency settings
# Leave empty to let the application choose automatically.
LLM_CONCURRENCY_PROFILE=auto
LLM_MAX_CONCURRENT=
LLM_TIMEOUT=60
LLM_MAX_RETRIES=5
